@* ===== 共通ページャー 部分ビュー ===== *@
@{
    int windowSize = 2; // 現在ページの前後に何ページ分のリンクを表示するかを指定する値（1なら現在位置から2つ目以降が…になる）
    int rangeStart = Math.Max(1, Model.CurrentPage - windowSize); //大きい方をスタートページにする
    int rangeEnd = Math.Min(Model.TotalPage, Model.CurrentPage + windowSize); //小さい方をエンドページにする
}
<nav aria-label="Page navigation">
    <ul class="pagination custom-pagination">
        @* 前へ：1ページ目は非活性 *@
        @if (Model.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-route-page="@(Model.CurrentPage - 1)">«前へ</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">«前へ</span></li>
        }

        @* 先頭省略 *@
        @if (rangeStart > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* メインページ番号 *@
        @for (int i = rangeStart; i <= rangeEnd; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" asp-route-page="@i">@i</a>
            </li>
        }

        @* 末尾省略 *@
        @if (rangeEnd < Model.TotalPage)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @* 次へ：最終ページは非活性 *@
        @if (Model.CurrentPage < Model.TotalPage)
        {
            <li class="page-item">
                <a class="page-link" asp-route-page="@(Model.CurrentPage + 1)">次へ»</a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">次へ»</span></li>
        }
    </ul>
</nav>